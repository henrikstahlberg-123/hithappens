---
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  lang?: 'sv' | 'en';
}

const { title = 'Hit Happens', lang = 'sv' } = Astro.props;
const [siteEntry] = await getCollection('settings');
const site = siteEntry.data;
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><polyline points='4,4 20,16 4,28' fill='none' stroke='%23e8412a' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/></svg>" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#2c1a0e" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
  <title>{title} – Hit Happens</title>
  <style is:global>
    *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
    :root{
      --bg:#f6f1ea;--bg2:#ede5d8;--bg3:#e2d5c3;
      --navy:#2c1a0e;--navy2:#3d2314;--navy3:#4f3020;
      --blue:#3d6b4f;--orange:#b8622a;--orange2:#cc7234;
      --text:#2c1a0e;--text2:#4a2f1a;
      --muted:#8a6f5a;--muted2:#b09880;
      --border:rgba(44,26,14,0.09);--border2:rgba(44,26,14,0.18);
      --max:1200px;--nav-h:56px;
      --font-serif:'Fraunces',Georgia,serif;
      --font-sans:'Inter','Segoe UI',system-ui,sans-serif
    }
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--font-sans);overflow-x:hidden}
    nav{position:fixed;top:0;width:100%;z-index:200;background:rgba(246,241,234,0.98);border-bottom:2px solid var(--orange)}
    .nav-inner{max-width:var(--max);margin:0 auto;height:var(--nav-h);display:flex;align-items:center;justify-content:space-between;padding:0 1.4rem}
    .nav-logo img{height:22px;width:auto}
    .nav-right{display:flex;align-items:center;gap:1rem}
    .nav-links{display:flex;gap:1.8rem;list-style:none}
    .nav-links a{color:var(--text2);text-decoration:none;font-size:0.78rem;letter-spacing:0.08em;text-transform:uppercase;transition:color 0.2s;padding-bottom:2px;border-bottom:2px solid transparent}
    .nav-links a:hover,.nav-links a[aria-current="page"]{color:var(--orange);border-bottom-color:var(--orange)}
    .btn{display:inline-block;text-align:center;padding:0.85rem 1.8rem;background:var(--navy);color:#fff;font-size:0.76rem;letter-spacing:0.12em;text-transform:uppercase;border-radius:2px;border:none;cursor:pointer;transition:background 0.2s;font-family:var(--font-sans);font-weight:600;text-decoration:none}
    .btn:hover{background:var(--navy2)}
    .btn-orange{background:var(--orange)}.btn-orange:hover{background:var(--orange2)}
    .page-hero{padding:calc(var(--nav-h) + 3rem) 1.4rem 3rem;background:var(--navy);position:relative;overflow:hidden;min-height:calc(var(--nav-h) + 220px)}
    .page-hero-inner{max-width:var(--max);margin:0 auto;position:relative;z-index:2}
    .page-kicker{font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--orange);margin-bottom:0.8rem;display:flex;align-items:center;gap:0.6rem}
    .page-kicker::before{content:'';width:16px;height:1.5px;background:var(--orange);display:block}
    .page-hero h1{font-family:var(--font-serif);font-size:clamp(2rem,5vw,3.5rem);font-weight:400;color:#fff;line-height:1.1;margin-bottom:1rem}
    .page-hero p{color:rgba(240,244,248,0.6);font-size:1rem;line-height:1.8;max-width:520px}
    .section{padding:4rem 1.4rem;border-top:1px solid var(--border)}
    .section-inner{max-width:var(--max);margin:0 auto}
    .sec-kicker{font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--orange);margin-bottom:0.6rem;display:flex;align-items:center;gap:0.6rem}
    .sec-kicker::before{content:'';width:14px;height:1.5px;background:var(--orange);display:block;flex-shrink:0}
    .sec-title{font-family:var(--font-serif);font-size:1.6rem;font-weight:400;color:var(--navy);margin-bottom:0.5rem}
    .sec-lead{color:var(--text2);font-size:0.88rem;line-height:1.7;margin-bottom:1.5rem}
    footer{padding:2rem 1.4rem;border-top:1px solid rgba(255,255,255,0.06);background:#0a1a2b}
    .footer-inner{max-width:var(--max);margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.5rem}
    footer p{font-size:0.7rem;color:rgba(255,255,255,0.25)}
    footer a{color:rgba(255,255,255,0.25);text-decoration:none;font-size:0.7rem}
    footer a:hover{color:rgba(255,255,255,0.5)}
    main{padding-top:var(--nav-h)}
    @media(max-width:767px){.nav-links{display:none}}
  </style>
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Hit Happens – startsida">
        <img src="/logo.png" alt="Hit Happens" onerror="this.style.display='none'" />
      </a>
      <div class="nav-right">
        <ul class="nav-links">
          <li><a href="/kollektioner" aria-current={Astro.url.pathname.startsWith('/kollektioner') ? 'page' : undefined}>{lang === 'sv' ? 'Serier' : 'Series'}</a></li>
          <li><a href="/tillverkningen" aria-current={Astro.url.pathname.startsWith('/tillverkningen') ? 'page' : undefined}>{lang === 'sv' ? 'Tillverkningen' : 'The craft'}</a></li>
          <li><a href="/artister" aria-current={Astro.url.pathname.startsWith('/artister') ? 'page' : undefined}>{lang === 'sv' ? 'Artister' : 'Artists'}</a></li>
          <li><a href="/merch" aria-current={Astro.url.pathname === '/merch' ? 'page' : undefined}>Merch</a></li>
          <li><a href="/rehab" aria-current={Astro.url.pathname === '/rehab' ? 'page' : undefined}>Rehab</a></li>
          <li><a href="/kontakt" aria-current={Astro.url.pathname === '/kontakt' ? 'page' : undefined}>{lang === 'sv' ? 'Kontakt' : 'Contact'}</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <slot />

  <footer>
    <div class="footer-inner">
      <a href="/">
        <img src="/logo.png" alt="Hit Happens" style="height:18px;width:auto;opacity:0.4" onerror="this.style.display='none'" />
      </a>
      <p>{lang === 'sv' ? site.taglineSv : site.taglineEn}</p>
    </div>
  </footer>
</body>
</html>
