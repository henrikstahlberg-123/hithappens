---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allSeries = await getCollection('series');
const series = allSeries.sort((a, b) => a.data.num.localeCompare(b.data.num));
const allArtists = await getCollection('artists');
const artists = allArtists.sort((a, b) => a.data.num.localeCompare(b.data.num));
const [siteEntry] = await getCollection('settings');
const site = siteEntry.data;
---

<Layout title="Handgjorda pukstockar">
  <!-- HERO -->
  <section style="min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;padding:2rem 1.4rem 3rem;position:relative;overflow:hidden">
    <img src={site.heroImage} alt="Hit Happens pukstockar" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;z-index:0" loading="eager" />
    <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(10,26,43,0.85) 0%,rgba(10,26,43,0.6) 40%,rgba(10,26,43,0.2) 70%,rgba(10,26,43,0) 100%),linear-gradient(to bottom,rgba(10,26,43,0) 0%,rgba(10,26,43,0.7) 85%);z-index:1;pointer-events:none"></div>
    <div style="position:relative;z-index:2;max-width:600px">
      <p style="font-size:0.75rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--orange);margin-bottom:1rem;display:flex;align-items:center;gap:0.7rem;font-weight:600">
        <span style="width:20px;height:2px;background:var(--orange);display:block;flex-shrink:0"></span>
        {site.taglineSv}
      </p>
      <h1 style="font-family:var(--font-serif);font-size:clamp(3rem,8vw,5.5rem);font-weight:400;line-height:1.05;color:#fff;margin-bottom:1.8rem">
        Känslan börjar<br>i <strong style="font-weight:400;color:var(--orange)">handen</strong>
      </h1>
      <p style="color:rgba(255,255,255,0.75);line-height:1.8;font-size:0.93rem;margin-bottom:2rem;max-width:460px">
        Fem serier. Handtillverkade i Sverige. Varje stock unik — som spelaren bakom den.
      </p>
      <div style="display:flex;flex-direction:column;gap:0.7rem">
        <a href="/kollektioner" class="btn btn-orange" style="display:block;text-align:center">Utforska serierna →</a>
        <a href="/tillverkningen" class="btn" style="display:block;text-align:center;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15)">Läs om hantverket</a>
      </div>
    </div>
  </section>

  <main>
    <!-- SERIER -->
    <section class="section">
      <div class="section-inner">
        <p class="sec-kicker">Kollektionen</p>
        <h2 class="sec-title">Fem serier</h2>
        <p class="sec-lead">Från bambu till valnöt — varje serie har sin egen karaktär.</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.6rem;margin-bottom:1.5rem">
          {series.map(s => (
            <a href={`/kollektioner#serie-${s.id}`} style="background:#fff;border:1px solid var(--border);border-radius:3px;padding:1rem;text-decoration:none;display:block;transition:border-color 0.2s,transform 0.15s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
              <span style={`font-family:var(--font-serif);font-size:0.85rem;color:var(--muted2);display:block;margin-bottom:0.2rem`}>{s.data.num}</span>
              <span style="font-family:var(--font-serif);font-size:1rem;color:var(--navy);display:block;margin-bottom:0.15rem">{s.data.nameSv}</span>
              <span style="font-size:0.7rem;color:var(--muted)">{s.data.models.length} modeller</span>
            </a>
          ))}
        </div>
        <a href="/kollektioner" style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-radius:6px;border:0.5px solid rgba(10,26,43,0.12);background:#fff;text-decoration:none;margin-top:1.2rem">
          <div>
            <span style="font-size:0.82rem;font-weight:600;color:var(--navy);display:block">Se alla modeller</span>
            <span style="font-size:0.7rem;color:var(--muted);display:block">Kork, Trä, Flanell, Läder och Special</span>
          </div>
          <div style="width:28px;height:28px;border-radius:50%;background:var(--orange);display:flex;align-items:center;justify-content:center;color:#fff">→</div>
        </a>
      </div>
    </section>

    <!-- ARTISTER -->
    <section class="section">
      <div class="section-inner">
        <p class="sec-kicker">Artister</p>
        <h2 class="sec-title">Proffs som väljer Hit Happens</h2>
        <p class="sec-lead">Pukslagare som ställer krav på varje detalj.</p>
        <div>
          {artists.map(a => (
            <div style="display:flex;align-items:center;gap:1rem;padding:1rem 0;border-bottom:1px solid var(--border)">
              <div style="width:48px;height:48px;border-radius:50%;background:var(--bg3);border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;font-family:var(--font-serif);font-size:0.95rem;color:var(--blue);flex-shrink:0">
                {a.data.initials}
              </div>
              <div>
                <span style="font-size:0.9rem;font-weight:600;color:var(--navy);display:block">{a.data.nameSv}</span>
                <span style="font-size:0.75rem;color:var(--muted)">{a.data.roleSv}</span>
              </div>
              <a href="/artister" style="font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--blue);text-decoration:none;margin-left:auto;white-space:nowrap">Se mer →</a>
            </div>
          ))}
        </div>
        <a href="/artister" style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-radius:6px;border:0.5px solid rgba(10,26,43,0.12);background:#fff;text-decoration:none;margin-top:1.5rem">
          <div>
            <span style="font-size:0.82rem;font-weight:600;color:var(--navy);display:block">Se alla artister</span>
            <span style="font-size:0.7rem;color:var(--muted);display:block">{artists.map(a => a.data.nameSv).join(', ')} m.fl.</span>
          </div>
          <div style="width:28px;height:28px;border-radius:50%;background:var(--orange);display:flex;align-items:center;justify-content:center;color:#fff">→</div>
        </a>
      </div>
    </section>

    <!-- REHAB -->
    <section class="section" style="background:var(--navy);border-top:none">
      <div class="section-inner">
        <p class="sec-kicker" style="color:var(--orange)">Rehab</p>
        <h2 class="sec-title" style="color:#fff">Ge dina stockar nytt liv</h2>
        <p class="sec-lead" style="color:rgba(240,244,248,0.6)">Slitna stockar behöver inte bytas ut.</p>
        <div style="font-family:var(--font-serif);font-size:2rem;color:#fff;margin-bottom:0.3rem">{site.rehabPriceSek} SEK</div>
        <div style="font-size:0.78rem;color:rgba(240,244,248,0.4);margin-bottom:1.5rem">/ par · inkl moms</div>
        <a href="/rehab" style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-radius:6px;border:0.5px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.06);text-decoration:none">
          <div>
            <span style="font-size:0.82rem;font-weight:600;color:#fff;display:block">Läs mer om Rehab</span>
            <span style="font-size:0.7rem;color:rgba(255,255,255,0.35);display:block">Ge dina stockar nytt liv från {site.rehabPriceSek} SEK</span>
          </div>
          <div style="width:28px;height:28px;border-radius:50%;background:var(--orange);display:flex;align-items:center;justify-content:center;color:#fff">→</div>
        </a>
      </div>
    </section>
  </main>
</Layout>
