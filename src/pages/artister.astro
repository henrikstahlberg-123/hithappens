---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArtists = await getCollection('artists');
const artists = allArtists.sort((a, b) => a.data.num.localeCompare(b.data.num));
const [siteEntry] = await getCollection('settings');
const site = siteEntry.data;
---

<Layout title="Artister" vibe="violet">
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-kicker">Artister</p>
      <h1>Proffs som väljer<br><em>Hit Happens</em></h1>
      <p>Pukslagare på världens scener.</p>
    </div>
  </div>

  <main>
    <section class="section">
      <div class="section-inner" style="display:flex;flex-direction:column;gap:1.5rem">
        {artists.map(a => (
          <article class="glass glass-grad lit artist reveal">
            <div class="artist-photo">
              {a.data.photo ? (
                <img src={a.data.photo} alt={a.data.nameSv} loading="lazy" />
              ) : (
                <span class="artist-initials">{a.data.initials}</span>
              )}
              <span class="artist-org">{a.data.orgSv}</span>
            </div>
            <div class="artist-info">
              <p class="artist-num">{a.data.num}</p>
              <h2 class="artist-name">{a.data.nameSv}</h2>
              <p class="artist-role">{a.data.roleSv}</p>
              <blockquote class="artist-quote">
                <p>{a.data.quoteSv}</p>
                <cite>— {a.data.nameSv}</cite>
              </blockquote>
              <p class="artist-bio">{a.data.bioSv}</p>
              <div class="artist-fav">Favoritmodell: <span>{a.data.modelSv}</span></div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" style="text-align:center">
      <div class="section-inner glass glass-grad lit" style="max-width:580px;padding:2.5rem">
        <span class="sec-kicker" style="margin-inline:auto">Endorsement</span>
        <h2 class="sec-title" style="margin-bottom:0.6rem">Spela <em>Hit Happens</em></h2>
        <p class="sec-lead" style="margin-inline:auto;margin-bottom:1.8rem">Proffspukslagare som vill testa våra stockar är varmt välkomna att höra av sig.</p>
        <a href={`mailto:${site.email}?subject=Artist endorsement`} class="btn">Hör av dig →</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .artist { display: grid; grid-template-columns: 1fr; gap: 0; overflow: hidden }
  .artist-photo {
    position: relative; aspect-ratio: 16/9; background: rgba(11,19,28,0.5);
    display: flex; align-items: center; justify-content: center;
  }
  .artist-photo img { width: 100%; height: 100%; object-fit: cover; display: block }
  .artist-initials { font-family: var(--font-serif); font-size: 4rem; color: var(--page); opacity: 0.4; line-height: 1 }
  .artist-org {
    position: absolute; bottom: 14px; left: 14px;
    background: rgba(var(--page-rgb),0.15); border: 1px solid rgba(var(--page-rgb),0.3);
    backdrop-filter: blur(8px); color: var(--cream);
    font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600;
    padding: 0.3rem 0.7rem; border-radius: 100px;
  }
  .artist-info { padding: 2rem }
  .artist-num {
    font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600;
    color: var(--page); margin-bottom: 0.5rem;
  }
  .artist-name { font-family: var(--font-serif); font-size: 2rem; font-weight: 400; color: var(--cream); line-height: 1.05; margin-bottom: 0.3rem }
  .artist-role { font-size: 0.78rem; letter-spacing: 0.06em; color: var(--text3); text-transform: uppercase; margin-bottom: 1.5rem }
  .artist-quote {
    border-left: 2px solid var(--page); padding: 0.9rem 1.2rem; margin-bottom: 1.5rem;
    background: rgba(var(--page-rgb),0.06); border-radius: 0 var(--r-sm) var(--r-sm) 0;
  }
  .artist-quote p { font-family: var(--font-serif); font-style: italic; font-size: 1.05rem; color: var(--cream2); line-height: 1.7 }
  .artist-quote cite { display: block; margin-top: 0.6rem; font-size: 0.74rem; color: var(--text3); font-style: normal }
  .artist-bio { font-size: 0.9rem; color: var(--text2); line-height: 1.8; margin-bottom: 1.5rem; font-weight: 300 }
  .artist-fav {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: rgba(242,233,216,0.04); border: 1px solid var(--border2); border-radius: 100px;
    padding: 0.5rem 1rem; font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text2);
  }
  .artist-fav span { color: var(--page); font-weight: 600 }

  @media (min-width: 720px) {
    .artist { grid-template-columns: 320px 1fr }
    .artist-photo { aspect-ratio: auto; height: 100% }
  }
</style>
