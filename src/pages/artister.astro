---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArtists = await getCollection('artists');
const artists = allArtists.sort((a, b) => a.data.num.localeCompare(b.data.num));
const [siteEntry] = await getCollection('settings');
const site = siteEntry.data;
---

<Layout title="Artister">
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-kicker">Artister</p>
      <h1>Proffs som väljer<br>Hit Happens</h1>
      <p>Pukslagare på världens scener.</p>
    </div>
  </div>

  <main>
    <section style="padding:5rem 1.4rem">
      <div style="max-width:var(--max);margin:0 auto">
        {artists.map(a => (
          <div style="padding:4rem 0;border-bottom:1px solid var(--border)">
            <div style="display:grid;grid-template-columns:1fr;gap:2.5rem">
              <div style="position:relative;background:var(--bg2);border-radius:4px;overflow:hidden;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;border:1px solid var(--border)">
                {a.data.photo ? (
                  <img src={a.data.photo} alt={a.data.nameSv} style="width:100%;height:100%;object-fit:cover;display:block" />
                ) : (
                  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.6rem">
                    <span style="font-family:var(--font-serif);font-size:3.5rem;color:var(--muted2);opacity:0.4;line-height:1">{a.data.initials}</span>
                  </div>
                )}
                <div style="position:absolute;bottom:12px;left:12px;background:var(--navy);color:#fff;font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.22rem 0.6rem;border-radius:2px;font-weight:600">
                  {a.data.orgSv}
                </div>
              </div>
              <div>
                <p style="font-size:0.68rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--orange);margin-bottom:0.5rem;display:flex;align-items:center;gap:0.5rem">
                  <span style="width:12px;height:1.5px;background:var(--orange);display:block"></span>
                  {a.data.num}
                </p>
                <h2 style="font-family:var(--font-serif);font-size:2rem;font-weight:400;color:var(--navy);margin-bottom:0.3rem;line-height:1.1">{a.data.nameSv}</h2>
                <p style="font-size:0.82rem;letter-spacing:0.06em;color:var(--muted);margin-bottom:1.5rem;text-transform:uppercase">{a.data.roleSv}</p>
                <blockquote style="border-left:2px solid var(--orange);padding:1rem 1.2rem;background:var(--bg2);border-radius:0 4px 4px 0;margin-bottom:1.5rem">
                  <p style="font-family:var(--font-serif);font-size:1rem;color:var(--text2);line-height:1.8;font-style:italic">{a.data.quoteSv}</p>
                  <cite style="display:block;margin-top:0.6rem;font-size:0.75rem;color:var(--muted);font-style:normal">— {a.data.nameSv}</cite>
                </blockquote>
                <p style="font-size:0.88rem;color:var(--text2);line-height:1.8;margin-bottom:1.5rem">{a.data.bioSv}</p>
                <div style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--bg2);border:1px solid var(--border2);border-radius:2px;padding:0.45rem 0.9rem;font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--text2)">
                  Favoritmodell: <span style="color:var(--orange);font-weight:600">{a.data.modelSv}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section style="padding:5rem 1.4rem;background:var(--bg2);border-top:1px solid var(--border)">
      <div style="max-width:var(--max);margin:0 auto">
        <div style="background:#fff;border:1px solid var(--border);border-radius:4px;padding:2rem;text-align:center;max-width:560px;margin:0 auto">
          <h3 style="font-family:var(--font-serif);font-size:1.3rem;font-weight:400;color:var(--navy);margin-bottom:0.6rem">Artist endorsement</h3>
          <p style="font-size:0.88rem;color:var(--text2);line-height:1.7;margin-bottom:1.5rem">Proffspukslagare som vill testa Hit Happens-stockar är välkomna.</p>
          <a href={`mailto:${site.email}?subject=Artist endorsement`} class="btn">Hör av dig</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
