---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const [siteEntry] = await getCollection('settings');
const site = siteEntry.data;

const steps = [
  { num: '1', title: 'Skicka in', text: 'Kontakta oss via mejl för adress och packningsinstruktioner.' },
  { num: '2', title: 'Vi renoverar', text: 'Filten byts, skaftet fräschas upp. Returfrakt ingår.' },
  { num: '3', title: 'Tillbaka till dig', text: 'Nyrenoverade stockar skickas tillbaka redo att spelas.' },
];
const included = ['Ny filt stansas och monteras', 'Skaftet fräschas upp', 'Silikongrepp byts vid behov', 'Lindning efterliknas', 'Returfrakt ingår'];
const priceRows = [
  { label: 'Ny filt', val: 'Ingår' },
  { label: 'Uppfräschning', val: 'Ingår' },
  { label: 'Returfrakt', val: 'Ingår' },
  { label: 'Leveranstid', val: 'ca 1–2 veckor' },
];
const formFields = [
  { id: 'r-name', label: 'Namn', type: 'text', placeholder: 'För- och efternamn', autocomplete: 'name' },
  { id: 'r-email', label: 'E-postadress', type: 'email', placeholder: 'din@email.se', autocomplete: 'email' },
  { id: 'r-pairs', label: 'Antal par', type: 'number', placeholder: 't.ex. 2', autocomplete: '' },
];
---

<Layout title="Rehab" vibe="amber">
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-kicker">Rehab</p>
      <h1>Ge dina stockar<br><em>nytt liv</em></h1>
      <p>Slitna stockar behöver inte bytas ut.</p>
    </div>
  </div>

  <main>
    <section class="section">
      <div class="section-inner">
        <div class="glass glass-grad lit reveal price-banner">
          <div>
            <div class="price-big"><span class="warm">{site.rehabPriceSek}</span> SEK <span class="price-unit">/ par · inkl moms</span></div>
            <div class="price-guarantee"><span>✓</span> Inte nöjd? Då gör vi om tills du är det.</div>
          </div>
          <a href="#rehab-form" class="btn">Boka Rehab →</a>
        </div>

        <div class="reveal" style="margin-top:3rem">
          <span class="sec-kicker">Så fungerar det</span>
          <h2 class="sec-title" style="margin-bottom:0.5rem">Tre enkla <em>steg</em></h2>
          <p class="sec-lead" style="margin-bottom:2rem">Från slitna stockar till som nya.</p>
        </div>
        <div class="step-grid">
          {steps.map(step => (
            <div class="glass lit reveal step">
              <div class="step-num">{step.num}</div>
              <div>
                <h3 class="step-title">{step.title}</h3>
                <p class="step-text">{step.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-inner" style="display:grid;grid-template-columns:1fr;gap:2.5rem">
        <div class="reveal">
          <span class="sec-kicker">Vad ingår</span>
          <h2 class="sec-title" style="margin-bottom:0.5rem">Komplett <em>uppfräschning</em></h2>
          <p class="sec-lead" style="margin-bottom:1.5rem">Vi gör ett grundligt jobb.</p>
          <div style="display:flex;flex-direction:column;gap:0.7rem">
            {included.map(item => (
              <div class="incl"><span class="warm">✓</span>{item}</div>
            ))}
          </div>
        </div>

        <div class="glass glass-grad lit reveal price-card">
          <div class="price-card-head">
            <h3>Rehab</h3>
            <div class="price-card-amount">{site.rehabPriceSek} SEK<span>inkl moms · per par</span></div>
          </div>
          <div class="price-card-body">
            {priceRows.map(row => (
              <div class="price-row"><span>{row.label}</span><span class="price-row-v">{row.val}</span></div>
            ))}
            <p class="price-note">Gäller alla märken och modeller.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="rehab-form" class="section" style="text-align:center">
      <div class="section-inner glass glass-grad lit" style="max-width:520px;padding:2.5rem">
        <span class="sec-kicker" style="margin-inline:auto">Boka</span>
        <h2 class="sec-title" style="margin-bottom:0.8rem">Redo att <em>boka</em>?</h2>
        <p class="sec-lead" style="margin-inline:auto;margin-bottom:2rem">Fyll i formuläret så återkommer vi med adress och instruktioner.</p>
        <form id="rehab-form-el" style="text-align:left">
          {formFields.map(field => (
            <div class="rf-field">
              <label for={field.id}>{field.label}</label>
              <input type={field.type} id={field.id} name={field.id} placeholder={field.placeholder} autocomplete={field.autocomplete} min={field.type === 'number' ? '1' : undefined} />
            </div>
          ))}
          <button type="button" onclick="sendRehab()" class="btn" style="width:100%;justify-content:center;margin-top:0.6rem">Boka Rehab →</button>
          <p class="rf-note">Vi återkommer med adress och packningsinstruktioner.</p>
        </form>
      </div>
    </section>
  </main>
</Layout>

<style>
  .warm { color: var(--warm2) }
  .price-banner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1.5rem; padding: 2rem }
  .price-big { font-family: var(--font-serif); font-size: 2.6rem; color: var(--cream); line-height: 1; margin-bottom: 0.9rem }
  .price-unit { font-family: var(--font-sans); font-size: 0.82rem; color: var(--text3); letter-spacing: 0.04em }
  .price-guarantee {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(255,201,128,0.08); border: 1px solid rgba(255,201,128,0.22); border-radius: 100px;
    padding: 0.5rem 1rem; font-size: 0.84rem; color: var(--text2);
  }

  .step-grid { display: grid; grid-template-columns: 1fr; gap: 1rem }
  .step { display: flex; gap: 1.2rem; align-items: flex-start; padding: 1.5rem }
  .step-num {
    width: 46px; height: 46px; border-radius: 50%; flex-shrink: 0;
    background: linear-gradient(135deg, var(--page), rgba(var(--page-rgb),0.6)); color: #fff;
    display: flex; align-items: center; justify-content: center; font-family: var(--font-serif); font-size: 1.2rem;
    box-shadow: 0 4px 16px rgba(var(--page-rgb),0.4);
  }
  .step-title { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 400; color: var(--cream); margin-bottom: 0.4rem }
  .step-text { font-size: 0.85rem; color: var(--text2); line-height: 1.7; font-weight: 300 }

  .incl { display: flex; align-items: center; gap: 0.7rem; font-size: 0.9rem; color: var(--text2) }

  .price-card { overflow: hidden; padding: 0 }
  .price-card-head {
    display: flex; align-items: center; justify-content: space-between; padding: 1.6rem 1.8rem;
    background: linear-gradient(135deg, rgba(var(--page-rgb),0.12), rgba(255,201,128,0.06));
    border-bottom: 1px solid var(--border2);
  }
  .price-card-head h3 { font-family: var(--font-serif); font-size: 1.3rem; font-weight: 400; color: var(--cream) }
  .price-card-amount { font-family: var(--font-serif); font-size: 1.9rem; color: var(--cream); line-height: 1; text-align: right }
  .price-card-amount span { font-family: var(--font-sans); font-size: 0.68rem; color: var(--text3); display: block; margin-top: 3px }
  .price-card-body { padding: 1.6rem 1.8rem }
  .price-row { display: flex; align-items: center; justify-content: space-between; padding: 0.8rem 0; border-bottom: 1px solid var(--border2); font-size: 0.88rem; color: var(--text2) }
  .price-row-v { color: var(--cream); font-weight: 600 }
  .price-note { margin-top: 1.2rem; padding-top: 1rem; border-top: 1px solid var(--border2); font-size: 0.8rem; color: var(--text3); line-height: 1.6 }

  .rf-field { margin-bottom: 0.9rem }
  .rf-field label { display: block; font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; color: var(--text2); margin-bottom: 0.4rem }
  .rf-field input {
    width: 100%; padding: 0.75rem 0.9rem; background: rgba(11,19,28,0.6);
    border: 1px solid var(--border2); border-radius: var(--r-sm); color: var(--cream);
    font-family: var(--font-sans); font-size: 0.9rem; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .rf-field input::placeholder { color: var(--text3) }
  .rf-field input:focus { outline: none; border-color: rgba(var(--page-rgb),0.6); box-shadow: 0 0 0 3px rgba(var(--page-rgb),0.12) }
  .rf-note { font-size: 0.75rem; color: var(--text3); margin-top: 0.8rem; text-align: center; line-height: 1.6 }

  @media (min-width: 760px) {
    .step-grid { grid-template-columns: repeat(3, 1fr) }
    .section-inner[style*="grid-template-columns:1fr"] { grid-template-columns: 1fr 1fr !important; align-items: start }
  }
</style>

<script define:vars={{ email: site.email }}>
function sendRehab() {
  const name = document.getElementById('r-name').value.trim();
  const userEmail = document.getElementById('r-email').value.trim();
  const pairs = document.getElementById('r-pairs').value.trim();
  if (!name || !userEmail || !pairs) { alert('Fyll i alla fält.'); return; }
  const subject = encodeURIComponent('Rehab-bokning');
  const body = encodeURIComponent(`Namn: ${name}\nE-post: ${userEmail}\nAntal par: ${pairs}`);
  window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
}
</script>
