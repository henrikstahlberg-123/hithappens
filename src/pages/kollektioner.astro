---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allSeries = await getCollection('series');
const series = allSeries.sort((a, b) => a.data.num.localeCompare(b.data.num));
---

<Layout title="Serier">
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-kicker">Serierna</p>
      <h1>Fem serier</h1>
      <p>Från bambu till valnöt — varje serie har sin egen karaktär.</p>
    </div>
  </div>

  <main>
    {series.map(s => (
      <section id={`serie-${s.id}`} class="section">
        <div class="section-inner">
          <div style="display:flex;align-items:baseline;gap:1rem;margin-bottom:0.5rem">
            <span style="font-family:var(--font-serif);font-size:1rem;color:var(--muted2)">{s.data.num}</span>
            <h2 style={`font-family:var(--font-serif);font-size:2rem;font-weight:400;color:var(--navy);border-left:4px solid ${s.data.color};padding-left:0.8rem`}>{s.data.nameSv}</h2>
          </div>
          <p style="color:var(--text2);font-size:0.92rem;line-height:1.7;margin-bottom:2rem;max-width:560px">{s.data.descSv}</p>

          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem">
            {s.data.models.map(m => (
              <div style="background:#fff;border:1px solid var(--border);border-radius:4px;overflow:hidden">
                {m.images.length > 0 ? (
                  <div style="aspect-ratio:4/3;overflow:hidden;background:var(--bg2)">
                    <img src={m.images[0]} alt={m.name} style="width:100%;height:100%;object-fit:cover;display:block" loading="lazy" />
                  </div>
                ) : (
                  <div style="aspect-ratio:4/3;background:var(--bg2);display:flex;align-items:center;justify-content:center">
                    <span style={`font-family:var(--font-serif);font-size:2rem;color:${s.data.color};opacity:0.3`}>{s.data.num}</span>
                  </div>
                )}
                <div style={`height:4px;background:${s.data.color}`}></div>
                <div style="padding:1.4rem">
                  <h3 style="font-family:var(--font-serif);font-size:1.25rem;font-weight:400;color:var(--navy);margin-bottom:0.3rem">{m.name}</h3>
                  <p style="font-size:0.84rem;color:var(--text2);line-height:1.65;margin-bottom:1rem">{m.descSv}</p>
                  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-bottom:1rem">
                    <div style="background:var(--bg);border:1px solid var(--border);border-radius:2px;padding:0.55rem 0.75rem">
                      <span style="font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:0.15rem">Material</span>
                      <span style="font-size:0.85rem;color:var(--navy);font-weight:500">{m.material}</span>
                    </div>
                    <div style="background:var(--bg);border:1px solid var(--border);border-radius:2px;padding:0.55rem 0.75rem">
                      <span style="font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:0.15rem">Hårdhet</span>
                      <span style="font-size:0.85rem;color:var(--navy);font-weight:500">{m.hardness}</span>
                    </div>
                    <div style="background:var(--bg);border:1px solid var(--border);border-radius:2px;padding:0.55rem 0.75rem">
                      <span style="font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:0.15rem">Längd</span>
                      <span style="font-size:0.85rem;color:var(--navy);font-weight:500">{m.length}</span>
                    </div>
                    <div style="background:var(--bg);border:1px solid var(--border);border-radius:2px;padding:0.55rem 0.75rem">
                      <span style="font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:0.15rem">Diameter</span>
                      <span style="font-size:0.85rem;color:var(--navy);font-weight:500">{m.diam}</span>
                    </div>
                  </div>
                  <div style="display:flex;align-items:center;justify-content:space-between;padding-top:1rem;border-top:1px solid var(--border)">
                    <div>
                      <div style="font-family:var(--font-serif);font-size:1.4rem;color:var(--navy);line-height:1">{m.priceSek.toLocaleString('sv-SE')} SEK</div>
                      <div style="font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-top:2px">/ par · inkl moms</div>
                    </div>
                    <div style={`display:inline-flex;align-items:center;gap:0.4rem;font-size:0.72rem;font-weight:500`}>
                      <span style={`width:8px;height:8px;border-radius:50%;flex-shrink:0;background:${m.status === 'instock' ? '#22c55e' : '#f59e0b'}`}></span>
                      {m.status === 'instock' ? 'I lager' : 'Beställningsvara'}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}

    <section style="padding:5rem 1.4rem;background:var(--navy);text-align:center">
      <div style="max-width:560px;margin:0 auto">
        <h2 style="font-family:var(--font-serif);font-size:clamp(1.8rem,4vw,2.6rem);font-weight:400;color:#fff;margin-bottom:1rem">Redo att beställa?</h2>
        <p style="color:rgba(240,244,248,0.6);font-size:0.95rem;line-height:1.8;margin-bottom:2.5rem">Kontakta oss via e-post för att lägga din beställning.</p>
        <a href="/kontakt" style="display:inline-block;padding:1rem 2.5rem;background:var(--orange);color:#fff;font-size:0.78rem;letter-spacing:0.12em;text-transform:uppercase;border-radius:2px;text-decoration:none;font-weight:700">Kontakta oss</a>
      </div>
    </section>
  </main>
</Layout>
