---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allMerch = await getCollection('merch');
const merch = allMerch.sort((a, b) => a.data.num.localeCompare(b.data.num));
const [siteEntry] = await getCollection('settings');
const site = siteEntry.data;
---

<Layout title="Merch">
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-kicker">Merch</p>
      <h1>Hit Happens<br>Merch</h1>
      <p>Bär varumärket. Beställ via mejl.</p>
      <a href={`mailto:${site.email}?subject=Merch-beställning`} class="btn btn-orange" style="display:inline-block;margin-top:1.5rem">Beställ merch</a>
    </div>
  </div>

  <main>
    <section style="padding:5rem 1.4rem">
      <div style="max-width:var(--max);margin:0 auto;display:flex;flex-direction:column;gap:5rem">
        {merch.map(item => (
          <div style={`display:grid;grid-template-columns:1fr;gap:2rem;${item.data.reverse ? '' : ''}`}>
            <div style="position:relative;background:var(--bg2);border-radius:4px;border:1px solid var(--border);overflow:hidden;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center">
              {item.data.image ? (
                <img src={item.data.image} alt={item.data.nameSv} style="width:100%;height:100%;object-fit:cover;display:block" loading="lazy" />
              ) : (
                <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.6rem;padding:2rem">
                  <span style="font-size:3rem;opacity:0.15">👜</span>
                  <span style="font-size:0.7rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted2)">{item.data.nameSv}</span>
                </div>
              )}
            </div>
            <div>
              <p style="font-size:0.68rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--orange);margin-bottom:0.5rem;display:flex;align-items:center;gap:0.5rem">
                <span style="width:12px;height:1.5px;background:var(--orange);display:block"></span>
                {item.data.num}
              </p>
              <h2 style="font-family:var(--font-serif);font-size:1.8rem;font-weight:400;color:var(--navy);margin-bottom:0.8rem;line-height:1.1">{item.data.nameSv}</h2>
              <p style="color:var(--text2);font-size:0.92rem;line-height:1.8;margin-bottom:1.5rem">{item.data.descSv}</p>
              <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:2rem">
                {item.data.detailsSv.map(d => (
                  <div style="display:flex;align-items:center;gap:0.7rem;font-size:0.85rem;color:var(--text2)">
                    <span style="width:6px;height:6px;border-radius:50%;background:var(--navy);flex-shrink:0"></span>
                    {d}
                  </div>
                ))}
              </div>
              <div style="display:flex;align-items:center;justify-content:space-between;padding-top:1.5rem;border-top:1px solid var(--border)">
                <span style="font-family:var(--font-serif);font-size:1.1rem;color:var(--muted)">Pris på förfrågan</span>
                <a href={`mailto:${site.email}?subject=Merch-beställning: ${item.data.nameSv}`} style="padding:0.7rem 1.4rem;background:var(--navy);color:#fff;font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;border-radius:2px;text-decoration:none;font-weight:600">Beställ</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section style="padding:5rem 1.4rem;background:var(--navy);text-align:center">
      <div style="max-width:560px;margin:0 auto">
        <h2 style="font-family:var(--font-serif);font-size:clamp(1.8rem,4vw,2.6rem);font-weight:400;color:#fff;margin-bottom:1rem">Intresserad?</h2>
        <p style="color:rgba(240,244,248,0.6);font-size:0.95rem;line-height:1.8;margin-bottom:2.5rem">Skicka ett mejl med produkter och storlek.</p>
        <a href={`mailto:${site.email}?subject=Merch-beställning`} style="display:inline-block;padding:1rem 2.5rem;background:var(--orange);color:#fff;font-size:0.78rem;letter-spacing:0.12em;text-transform:uppercase;border-radius:2px;text-decoration:none;font-weight:700">Skicka beställning</a>
      </div>
    </section>
  </main>
</Layout>
