---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allMerch = await getCollection('merch');
const merch = allMerch.sort((a, b) => a.data.num.localeCompare(b.data.num));
const [siteEntry] = await getCollection('settings');
const site = siteEntry.data;
---

<Layout title="Merch" vibe="green">
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-kicker">Merch</p>
      <h1>Hit Happens<br><em>Merch</em></h1>
      <p>Bär varumärket. Beställ via mejl.</p>
      <a href={`mailto:${site.email}?subject=Merch-beställning`} class="btn" style="margin-top:1.5rem">Beställ merch →</a>
    </div>
  </div>

  <main>
    <section class="section">
      <div class="section-inner" style="display:flex;flex-direction:column;gap:1.5rem">
        {merch.map(item => (
          <article class="glass glass-grad lit merch reveal">
            <div class="merch-img">
              {item.data.image ? (
                <img src={item.data.image} alt={item.data.nameSv} loading="lazy" />
              ) : (
                <span class="merch-ph">{item.data.nameSv}</span>
              )}
            </div>
            <div class="merch-info">
              <p class="merch-num">{item.data.num}</p>
              <h2 class="merch-name">{item.data.nameSv}</h2>
              <p class="merch-desc">{item.data.descSv}</p>
              <div class="merch-details">
                {item.data.detailsSv.map(d => (
                  <div class="merch-detail"><span class="dot"></span>{d}</div>
                ))}
              </div>
              <div class="merch-foot">
                <span class="merch-price">Pris på förfrågan</span>
                <a href={`mailto:${site.email}?subject=Merch-beställning: ${item.data.nameSv}`} class="btn">Beställ →</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" style="text-align:center">
      <div class="section-inner glass glass-grad lit" style="max-width:580px;padding:2.5rem">
        <span class="sec-kicker" style="margin-inline:auto">Intresserad?</span>
        <h2 class="sec-title" style="margin-bottom:0.6rem">Skicka en <em>beställning</em></h2>
        <p class="sec-lead" style="margin-inline:auto;margin-bottom:1.8rem">Skicka ett mejl med produkter och storlek så återkommer vi med pris.</p>
        <a href={`mailto:${site.email}?subject=Merch-beställning`} class="btn">Skicka beställning →</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .merch { display: grid; grid-template-columns: 1fr; overflow: hidden }
  .merch-img { aspect-ratio: 16/9; background: rgba(11,19,28,0.5); display: flex; align-items: center; justify-content: center }
  .merch-img img { width: 100%; height: 100%; object-fit: cover; display: block }
  .merch-ph { font-family: var(--font-serif); font-size: 1.4rem; color: var(--text3); opacity: 0.6 }
  .merch-info { padding: 2rem }
  .merch-num { font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600; color: var(--page); margin-bottom: 0.5rem }
  .merch-name { font-family: var(--font-serif); font-size: 1.8rem; font-weight: 400; color: var(--cream); line-height: 1.1; margin-bottom: 0.8rem }
  .merch-desc { font-size: 0.92rem; color: var(--text2); line-height: 1.8; margin-bottom: 1.5rem; font-weight: 300 }
  .merch-details { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.8rem }
  .merch-detail { display: flex; align-items: center; gap: 0.7rem; font-size: 0.85rem; color: var(--text2) }
  .merch-detail .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--page); flex-shrink: 0 }
  .merch-foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-top: 1.5rem; border-top: 1px solid var(--border2); flex-wrap: wrap }
  .merch-price { font-family: var(--font-serif); font-size: 1.05rem; color: var(--text2) }

  @media (min-width: 760px) {
    .merch { grid-template-columns: 360px 1fr }
    .merch-img { aspect-ratio: auto; height: 100% }
  }
</style>
